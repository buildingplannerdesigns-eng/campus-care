# ─────────────────────────────────────────────
# Campus Care 2.0 — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────

# Sanity CMS (content: programs, gallery, team, news)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Supabase (stores donation records)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Donorbox (hosted donation checkout)
NEXT_PUBLIC_DONORBOX_CAMPAIGN_URL=

# Cloudflare Turnstile (contact form bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend (donation receipts, contact/volunteer form notifications)
RESEND_API_KEY=
RESEND_FROM_EMAIL=donations@campuscare2.org
CONTACT_NOTIFICATION_EMAIL=hello@campuscare2.org

# Site
NEXT_PUBLIC_SITE_URL=https://campuscare2.org
